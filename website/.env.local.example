# Public fleet-status endpoint the storefront polls for the live status badge.
# Points at the bot's fleet server (bot/src/fleet/server.js) → GET /public/status.
# In production use your bot host's public URL, e.g. https://fleet.hynexbots.com/public/status
NEXT_PUBLIC_FLEET_STATUS_URL=http://localhost:8787/public/status

# Discord invite every CTA links to, and the contact email.
NEXT_PUBLIC_DISCORD_INVITE=https://discord.gg/your-invite
NEXT_PUBLIC_CONTACT_EMAIL=hello@hynexbots.com

# Headline stats shown on the homepage. Set to your real figures.
NEXT_PUBLIC_STAT_DELIVERED=400
NEXT_PUBLIC_STAT_RATING=4.9
NEXT_PUBLIC_STAT_DELIVERY_H=24
NEXT_PUBLIC_STAT_SERVERS=180

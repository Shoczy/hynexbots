# ── Discord ──────────────────────────────────────────
# Bot token from the Discord Developer Portal (this is the sold bot's own app).
# IMPORTANT: enable the "Message Content Intent" and "Server Members Intent"
# under Bot → Privileged Gateway Intents, or the bot can't start.
DISCORD_TOKEN=

# ── Hynex config service ─────────────────────────────
# Where the main Hynex bot's config API lives (the Express server on :8787).
CONFIG_API_URL=http://localhost:8787
# Shared bot key — must match CONFIG_BOT_KEY / FLEET_SECRET on the main bot.
CONFIG_BOT_KEY=
# How often (seconds) to re-poll the dashboard for config changes.
CONFIG_POLL_SEC=30

# ── In-game intake (optional) ────────────────────────
# Only needed for IN-GAME REPORTS and the WHITELIST CHECK endpoint. Leave the
# port blank to disable the HTTP intake entirely (status, whitelist management
# and restart announcements all still work — they're Discord-side).
# The port your FiveM server can reach this bot on:
FIVEM_INGRESS_PORT=
# A shared secret your FiveM resource must send with every request:
FIVEM_INGRESS_SECRET=

# Note: the bot's Application ID is read automatically from the token
# (client.application.id) — there is nothing to set here.

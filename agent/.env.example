# ─────────────────────────────────────────────
#  Hynex fleet agent — run one per VPS
# ─────────────────────────────────────────────

# Where the main bot's heartbeat server lives.
# Example: http://203.0.113.10:8787  (the VPS/host running the main bot)
FLEET_URL=http://your-main-bot-host:8787

# Must match FLEET_SECRET in the main bot's .env
FLEET_SECRET=change-me-to-a-long-random-string

# A friendly id for this VPS (shown in /fleet). Defaults to the hostname.
NODE_ID=vps-1

# How often to report, in seconds.
INTERVAL_SEC=30

# How bots are discovered on this VPS:
#   pm2    → run `pm2 jlist` and report all PM2 processes (recommended)
#   static → report the names in BOTS below as "online"
BOT_SOURCE=pm2

# Used only when BOT_SOURCE=static. Comma-separated bot names.
BOTS=my-bot-1,my-bot-2

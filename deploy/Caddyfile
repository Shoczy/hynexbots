# ─────────────────────────────────────────────────────────────
#  Hynex Bots — Caddy reverse proxy with automatic HTTPS
# ─────────────────────────────────────────────────────────────
#
# This box runs the MAIN BOT only (Discord client + the Express config/fleet API
# on port 8787, and it spawns the sold product bots locally). Website + dashboard
# live on Vercel, so Caddy here only needs to put TLS in front of the bot API —
# remote VPS agents and the public status page reach it over HTTPS.
#
#   sudo cp deploy/Caddyfile /etc/caddy/Caddyfile   # edit the domain first!
#   sudo systemctl reload caddy
#
# Requirements:
#   • DNS A/AAAA record for api.yourdomain.com → this host.
#   • Ports 80 and 443 open (Caddy needs 80 for the ACME challenge).
#   • The bot's FLEET_PORT stays bound to localhost — only Caddy is public.
#
# Then on Vercel:
#   dashboard  CONFIG_API_URL                = https://api.yourdomain.com
#   website    NEXT_PUBLIC_FLEET_STATUS_URL  = https://api.yourdomain.com/public/status

api.yourdomain.com {
	encode zstd gzip

	# Agents and the dashboard send small JSON payloads; keep bodies bounded.
	request_body {
		max_size 512KB
	}

	reverse_proxy localhost:8787

	log {
		output file /var/log/caddy/hynex-api.log
		format console
	}
}

# ── Self-hosting the frontends instead of Vercel? ─────────────
# If you ever move the website + dashboard onto this box (PM2: next start on
# :3000 and :3001), uncomment below. The website already proxies /dashboard to
# the dashboard internally, so only the website needs to be public.
#
# yourdomain.com, www.yourdomain.com {
# 	encode zstd gzip
# 	reverse_proxy localhost:3000
# }

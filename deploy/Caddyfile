# ─────────────────────────────────────────────────────────────
#  Hynex Bots — Caddy reverse proxy with automatic HTTPS
# ─────────────────────────────────────────────────────────────
#
# Caddy fronts the main bot's HTTP server (fleet heartbeats + the customer
# config API, default port 8787) and terminates TLS for you — it provisions and
# renews Let's Encrypt certificates automatically. No certbot, no cron.
#
#   sudo apt install caddy           # or see https://caddyserver.com/docs/install
#   sudo cp deploy/Caddyfile /etc/caddy/Caddyfile   # edit the domains first
#   sudo systemctl reload caddy
#
# Requirements:
#   • DNS A/AAAA records for each domain below pointing at this host.
#   • Ports 80 and 443 open (Caddy needs 80 for the ACME challenge).
#   • The bot's FLEET_PORT stays bound to localhost — only Caddy is public.
#
# After this is live, point the apps at the HTTPS URLs:
#   dashboard  CONFIG_API_URL=https://api.example.com
#   website    NEXT_PUBLIC_FLEET_STATUS_URL=https://api.example.com/public/status

# Main bot API — fleet heartbeats + dashboard/bot config service.
api.example.com {
	encode zstd gzip

	# Agents and the dashboard send a bit of JSON; keep bodies bounded.
	request_body {
		max_size 512KB
	}

	reverse_proxy localhost:8787

	log {
		output file /var/log/caddy/hynex-api.log
		format console
	}
}

# Optional: the storefront website, if you host it on this box too.
# (On Vercel you don't need this — Vercel handles TLS.)

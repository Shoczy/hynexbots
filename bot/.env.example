# ─────────────────────────────────────────────
#  Hynex Bots — main bot configuration
# ─────────────────────────────────────────────

# Discord bot token (Developer Portal → Bot → Reset Token)
DISCORD_TOKEN=your-bot-token-here

# Application (client) ID — Developer Portal → General Information
CLIENT_ID=your-application-id

# Your server (guild) ID. Slash commands deploy here instantly.
# Right-click your server icon → Copy Server ID (needs Developer Mode on).
GUILD_ID=your-server-id

# ── Tickets ──────────────────────────────────
# Category ID where ticket channels are created (optional — auto-created if blank)
TICKET_CATEGORY_ID=
# Role ID for staff who can see/manage tickets (mention pinged on new tickets)
STAFF_ROLE_ID=
# Channel ID where closed-ticket transcripts are posted (optional)
TRANSCRIPT_CHANNEL_ID=

# ── Fleet monitor ────────────────────────────
# Port the heartbeat HTTP server listens on (agents POST here)
FLEET_PORT=8787
# Shared secret. Every VPS agent must send this in the Authorization header.
FLEET_SECRET=change-me-to-a-long-random-string
# Minutes without a heartbeat before a VPS is shown as OFFLINE
FLEET_OFFLINE_AFTER_MIN=2
# Channel ID for node/bot up·down alerts (optional). Owners are DMed regardless.
FLEET_ALERT_CHANNEL_ID=
# Minutes without contact before a CUSTOMER bot is treated as offline (alerts +
# per-bot incident log). Higher than the VPS value to avoid false alarms.
BOT_OFFLINE_AFTER_MIN=10

# ── Customer dashboard / config API ──────────────
# Shared secret the Next.js dashboard uses for server-to-server calls.
# Must match DASHBOARD_API_KEY in the dashboard's .env.local
DASHBOARD_API_KEY=change-me-to-a-long-random-dashboard-key
# Secret a customer's running bot uses to fetch its config.
# Defaults to FLEET_SECRET if left blank.
CONFIG_BOT_KEY=

# ─────────────────────────────────────────────
#  Hynex Bots — dashboard config
# ─────────────────────────────────────────────

# The dashboard is mounted under /dashboard and served via the public site on one
# origin (the site proxies /dashboard/* here). Override the base path if needed —
# it must match website's proxy. Default: /dashboard
# NEXT_PUBLIC_BASE_PATH=/dashboard

# Discord OAuth2 app (same application as your bot is fine).
# Developer Portal → OAuth2. Add this redirect URL there (note the /dashboard prefix):
#   http://localhost:3000/dashboard/api/auth/callback   (and your production URL)
DISCORD_CLIENT_ID=your-application-id
DISCORD_CLIENT_SECRET=your-oauth2-client-secret
DISCORD_REDIRECT_URI=http://localhost:3000/dashboard/api/auth/callback

# Where the bot's config service (Express, in bot/) is reachable.
CONFIG_API_URL=http://localhost:8787
# Must match DASHBOARD_API_KEY in the bot's .env
DASHBOARD_API_KEY=change-me-to-a-long-random-dashboard-key

# Secret used to encrypt+sign the login session cookie (AES-256-GCM).
# REQUIRED in production. Generate one with:  openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-session-secret
